      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by(le, node_ip) (rate(llm_request_latency_ms_bucket{node_ip!=\"stream\",node_ip!=\"unknown\"}[5m])))",
          "legendFormat": "{{node_ip}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
