{
  "title": "ONGC Worker Node Health",
  "uid": "worker-health",
  "schemaVersion": 37,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [

    {
      "id": 1,
      "title": "Cluster Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "panels": []
    },

    {
      "id": 2,
      "title": "Ray Nodes Online",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 3},
              {"color": "green", "value": 4}
            ]
          },
          "mappings": [],
          "min": 0,
          "max": 4
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(up{job=\"node-exporter\"} == 1)",
          "legendFormat": "nodes up",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },

    {
      "id": 3,
      "title": "All Nodes — CPU %",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {"lineWidth": 1, "fillOpacity": 10}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - avg by(instance)(rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[2m])*100)",
          "legendFormat": "{{instance}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },

    {
      "id": 4,
      "title": "All Nodes — GPU Utilization %",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {"lineWidth": 1, "fillOpacity": 10}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvidia_smi_utilization_gpu_ratio * 100",
          "legendFormat": "{{instance}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },

    {
      "id": 5,
      "title": "All Nodes — VRAM Used",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "bytes",
          "custom": {"lineWidth": 1, "fillOpacity": 10}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nvidia_smi_memory_used_bytes",
          "legendFormat": "{{instance}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },

    {
      "id": 6,
      "title": "All Nodes — Token Throughput (tokens/sec)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "short",
          "custom": {"lineWidth": 1, "fillOpacity": 10}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(llamacpp:tokens_predicted_total[2m])",
          "legendFormat": "{{instance}}",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ]
    },

